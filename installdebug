#!/bin/bash

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
LOG_FILE="$DIR/output.log"
ADB="$HOME/Android/Sdk/platform-tools/adb"

export JAVA_HOME="$DIR/jdk17"

# ── ANSI colors ──
C_RESET="\e[0m"
C_BOLD="\e[1m"
C_RED="\e[31m"
C_GREEN="\e[32m"
C_YELLOW="\e[33m"
C_CYAN="\e[36m"

now() { date '+%H:%M:%S'; }

$ADB start-server 2>/dev/null

echo -e "${C_CYAN}[$(now)]${C_RESET} ${C_BOLD}Aguardando dispositivo...${C_RESET}"
echo "   (Ctrl+C para cancelar)"
echo ""

while true; do
    devices=$($ADB devices | grep -w "device" | cut -f1)

    if [ -n "$devices" ]; then
        echo ""
        echo -e "✅ Dispositivo conectado. Iniciando compilação..."
        break
    fi

    attached=$($ADB devices | grep -v "List of devices" | grep -v "^$" | head -1)
    if [ -n "$attached" ]; then
        status=$(echo "$attached" | awk '{print $2}')
        echo -e "⚠️  Dispositivo '$status' — autorize no dispositivo e aguarde..."
        sleep 2
        continue
    fi

    # Descobre dispositivos via avahi (mDNS) na rede local
    echo -ne "\r🔍 Procurando dispositivos na rede..."
    found=false

    for service in "_adb-tls-connect._tcp" "_adb._tcp"; do
        while IFS=';' read -r iface proto name svc domain host addr port txt; do
            if [ "$svc" = "$service" ] && [ -n "$addr" ] && [ -n "$port" ]; then
                if ! $ADB devices 2>/dev/null | grep -q "$addr:$port"; then
                    echo ""
                    echo "📡 Conectando a $addr:$port (avahi)..."
                    $ADB connect "$addr:$port" 2>/dev/null &
                fi
                found=true
            fi
        done < <(avahi-browse -trp "$service" 2>/dev/null | grep "^=")
    done

    if [ "$found" = false ]; then
        echo -ne "\r⏳ Nenhum dispositivo na rede. Conecte via USB ou ative 'Depuração sem fio' no Android."
    fi

    sleep 3
done

exec > >(tee "$LOG_FILE") 2>&1

echo ""
echo -e "${C_CYAN}[$(now)]${C_RESET} ./gradlew installDebug -q"
echo ""
START_NS=$(date +%s%N)

"$DIR/gradlew" installDebug -q "$@"
EXIT=$?

END_NS=$(date +%s%N)
ELAPSED_MS=$(( (END_NS - START_NS) / 1000000 ))

if (( ELAPSED_MS < 1000 )); then
    ELAPSED="${ELAPSED_MS}ms"
elif (( ELAPSED_MS < 60000 )); then
    ELAPSED="$(awk "BEGIN {printf \"%.1f\", $ELAPSED_MS / 1000}")s"
else
    MINS=$(( ELAPSED_MS / 60000 ))
    SECS=$(awk "BEGIN {printf \"%.1f\", ($ELAPSED_MS % 60000) / 1000}")
    ELAPSED="${MINS}m ${SECS}s"
fi

echo ""

if [ $EXIT -eq 0 ]; then
    echo -e "${C_GREEN}${C_BOLD}[BUILD SUCCESS]${C_RESET}  ${C_CYAN}$(now)${C_RESET}  ${ELAPSED}"

    devices=$($ADB devices | grep -w "device" | cut -f1)
    for device in $devices; do
        echo "📲 Iniciando o aplicativo no dispositivo: $device..."
        $ADB -s "$device" shell am start -n com.chopcut/com.chopcut.MainActivity
    done
    echo -e "${C_CYAN}$(now)${C_RESET} ${C_GREEN}Instalação concluída com sucesso!${C_RESET}"
else
    echo -e "${C_RED}${C_BOLD}[BUILD FAILED]${C_RESET}  ${C_CYAN}$(now)${C_RESET}  ${ELAPSED}"
    echo -e "${C_RED}Ocorreu um erro durante a compilação ou instalação.${C_RESET}"
    exit 1
fi
