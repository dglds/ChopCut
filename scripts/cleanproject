#!/bin/bash

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
LOG_FILE="$DIR/output.log"

export JAVA_HOME="$DIR/../jdk17"

exec > >(tee "$LOG_FILE") 2>&1

# ── ANSI colors ──
C_RESET="\e[0m"
C_BOLD="\e[1m"
C_RED="\e[31m"
C_GREEN="\e[32m"
C_YELLOW="\e[33m"
C_CYAN="\e[36m"

now() { date '+%H:%M:%S'; }

echo -e "${C_CYAN}[$(now)]${C_RESET} ${C_BOLD}Iniciando limpeza profunda do ChopCut...${C_RESET}"
echo ""

# 1. Limpando cache do Gradle (.gradle do projeto)
echo -e "${C_YELLOW}[1/4] Removendo pasta de caches locais .gradle...${C_RESET}"
if [ -d "$DIR/../.gradle" ]; then
    rm -rf "$DIR/../.gradle"
    echo -e "${C_GREEN}✅ Caches locais do Gradle limpos!${C_RESET}"
else
    echo -e "   Nenhum cache local encontrado."
fi

# 2. Limpando compilações Kotlin
echo -e "${C_YELLOW}[2/4] Removendo caches locais do Kotlin...${C_RESET}"
if [ -d "$DIR/../.kotlin" ]; then
    rm -rf "$DIR/../.kotlin"
    echo -e "${C_GREEN}✅ Caches locais do Kotlin limpos!${C_RESET}"
else
    echo -e "   Nenhum cache local do Kotlin encontrado."
fi

# 3. Limpeza dos diretórios build, .cxx e temporários do projeto
echo -e "${C_YELLOW}[3/4] Eliminando pastas build, .cxx e compilações NDK...${C_RESET}"
find "$DIR/.." -type d -name "build" -exec rm -rf {} + 2>/dev/null
find "$DIR/.." -type d -name ".externalNativeBuild" -exec rm -rf {} + 2>/dev/null
find "$DIR/.." -type d -name ".cxx" -exec rm -rf {} + 2>/dev/null
echo -e "${C_GREEN}✅ Pastas de compilação manuais deletadas!${C_RESET}"

# 4. Executando gradlew clean
echo -e "${C_YELLOW}[4/4] Executando gradlew clean...${C_RESET}"
if [ -f "$DIR/../gradlew" ]; then
    "$DIR/../gradlew" clean -q
    if [ $? -eq 0 ]; then
        echo -e "${C_GREEN}✅ gradlew clean executado com sucesso!${C_RESET}"
    else
        echo -e "${C_RED}❌ Falha ao executar gradlew clean.${C_RESET}"
    fi
else
    echo -e "${C_RED}❌ gradlew não encontrado no diretório $DIR/..${C_RESET}"
fi

echo ""
echo -e "${C_GREEN}${C_BOLD}[CLEAN SUCCESS]${C_RESET}  ${C_CYAN}$(now)${C_RESET}"
echo -e "O projeto está totalmente limpo e pronto para uma nova compilação!"
