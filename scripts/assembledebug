#!/bin/bash

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
LOG_FILE="$DIR/output.log"

export JAVA_HOME="$DIR/../jdk17"

exec > >(tee "$LOG_FILE") 2>&1

echo "🚀 Compilando ChopCut (assembleDebug)..."
"$DIR/../gradlew" assembleDebug "$@"

if [ $? -eq 0 ]; then
    echo "✅ Compilação concluída com sucesso!"
    echo "🕒 Executado em: $(date '+%Y-%m-%d %H:%M:%S')"
    ffplay -nodisp -autoexit -loglevel quiet "/home/diego/Downloads/efeitos-sonoros-brasil-sil-sil-rede-globo.mp3" 2>/dev/null &
else
    echo ""
    echo "FAILURE:"
    awk '/^FAILURE:/{found=1} found{print; if(/^BUILD FAILED/){exit}}' "$LOG_FILE"
    echo "🕒 Executado em: $(date '+%Y-%m-%d %H:%M:%S')"
    python3 "$DIR/log_build_error.py" "assembleDebug"
    exit 1
fi
