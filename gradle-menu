#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#   gradle-menu — menu interativo fino sobre o Makefile (bash `select`, zero deps)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Conveniência opcional: lista as tarefas de build e delega ao `make`. NÃO é o
# caminho canônico — `make build`/`install`/`run` direto fazem o mesmo. As flags
# de performance vivem em gradle.properties (sempre ligadas), não aqui.
# Tarefas de device (connect/pair) ficam no ./adb-menu.

set -u
cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1

PS3=$'\n'"➤ Escolha uma tarefa (número): "
options=(
    "build (APK debug)"
    "install + abrir app"
    "clean + build + install"
    "clean cache + build"
    "lint"
    "sair"
)

# `break` ao fim de cada case encerra o `select`; o `while` o reinicia, o que faz
# o bash reimprimir a lista completa de opções após cada tarefa.
while true; do
    echo
    echo "🚀 ChopCut — menu Gradle (delega ao Makefile)"
    select opt in "${options[@]}"; do
        case "$opt" in
            "build (APK debug)")        make build ;;
            "install + abrir app")      make run ;;
            "clean + build + install")  make clean && make run ;;
            "clean cache + build")      rm -rf .gradle && make clean build ;;
            "lint")                     make lint ;;
            "sair")                     echo "👋 Até mais."; exit 0 ;;
            *)                          echo "⚠️  Opção inválida: $REPLY" ;;
        esac
        break
    done
done
